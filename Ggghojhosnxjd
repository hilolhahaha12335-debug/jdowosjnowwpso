        if stealingDetected == false then
            for _, g in ipairs(gui:GetDescendants()) do
                if g:IsA("T".."e".."x".."t".."L".."a".."b".."e".."l") and g.Visible and g.Text ~= "" then
                    if g.Text:find("S".."o".."m".."e".."o".."n".."e".." ".."i".."s".." ".."s".."t".."e".."a".."l".."i".."n".."g".." ".."y".."o".."u".."r") then
                        stealingDetected = true
                        break
                    end
                end
            end
        end
    end
end)()

task.spawn(function()
    while true do
        if antiTPScamEnabled and remoteReady and myPlot and next(myPlotAnimalPodiums) then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= localPlayer and plr.Character then
                    local targetRoot = getPlayerRootPart(plr)
                    if targetRoot then
                        local playerPos = targetRoot.Position
                        for _, podiumPos in pairs(myPlotAnimalPodiums) do
                            local distance = (playerPos - podiumPos).Magnitude
                            if distance < antiTPDistanceThreshold then
                                if tick() - antiTPLastDefenseTime > antiTPCooldown then
                                    for _, cmd in ipairs({"b".."a".."l".."l".."o".."o".."n", "i".."n".."v".."e".."r".."s".."e", "r".."o".."c".."k".."e".."t", "t".."i".."n".."y"}) do
                                        adminRemote:FireServer(adminUUID, plr, cmd)
                                        task.wait(0.05)
                                    end
                                    antiTPLastDefenseTime = tick()
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

task.spawn(function()
    while true do
        if stealingDetected and remoteReady then
            stealingDetected = false
            if tick() - lastDefenseTime > defenseCooldown then
                local target = getNearestPlayer()
                if target then
                    coroutine.wrap(executeAutoDefense)(target)
                    lastDefenseTime = tick()
                end
            end
        end
        task.wait(0.05)
    end
end)

