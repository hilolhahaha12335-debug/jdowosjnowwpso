local function findMyPlot()
    local plotsFolder = Workspace:FindFirstChild("P".."l".."o".."t".."s")
    if not plotsFolder then return nil end
    for _, plot in pairs(plotsFolder:GetChildren()) do
        local plotSign = plot:FindFirstChild("P".."l".."o".."t".."S".."i".."g".."n")
        if plotSign then
            local surfaceGui = plotSign:FindFirstChild("S".."u".."r".."f".."a".."c".."e".."G".."u".."i")
            if surfaceGui then
                local frame = surfaceGui:FindFirstChild("F".."r".."a".."m".."e")
                if frame then
                    local textLabel = frame:FindFirstChild("T".."e".."x".."t".."L".."a".."b".."e".."l")
                    if textLabel and textLabel:IsA("T".."e".."x".."t".."L".."a".."b".."e".."l") then
                        local plotText = textLabel.Text
                        if plotText:find(myDisplayName) and plotText:find("'".."s".." ".."B".."a".."s".."e") then
                            return plot
                        end
                    end
                end
            end
        end
    end
    return nil
end

local function getMyPlotAnimalPodiums(plot)
    local podiumPositions = {}
    local animalPodiumsFolder = plot:FindFirstChild("A".."n".."i".."m".."a".."l".."P".."o".."d".."i".."u".."m".."s")
    if not animalPodiumsFolder then return podiumPositions end
    for i = 1, 10 do
        local podium = animalPodiumsFolder:FindFirstChild(tostring(i))
        if podium and podium:IsA("M".."o".."d".."e".."l") then
            podiumPositions[i] = podium:GetPivot().Position
        end
    end
    return podiumPositions
end

local function getPlayerRootPart(plr)
    local char = plr.Character
    if not char then return nil end
    return char:FindFirstChild("H".."u".."m".."a".."n".."o".."i".."d".."R".."o".."o".."t".."P".."a".."r".."t")
end

local function getPlayersInMyPlot()
    if not myPlot then return {} end
    local players = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local hrp = getPlayerRootPart(p)
            if hrp then
                for _, podiumPos in ipairs(myPlotAnimalPodiums) do
                    if (hrp.Position - podiumPos).Magnitude < 8 then
                        table.insert(players, p)
                        break
                    end
                end
            end
        end
    end
    return players
end

local function getNearestPlayer()
    local char = localPlayer.Character
    if not char or not char:FindFirstChild("H".."u".."m".."a".."n".."o".."i".."d".."R".."o".."o".."t".."P".."a".."r".."t") then return nil end
    local hrp = char.HumanoidRootPart
    local nearest, shortest = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local phrp = getPlayerRootPart(p)
            if phrp then
                local dist = (hrp.Position - phrp.Position).Magnitude
                if dist < shortest then
                    shortest = dist
                    nearest = p
                end
            end
        end
    end
    return nearest
end

local function executeBaseDefenderNear(target)
    adminRemote:FireServer(adminUUID, target, "r".."a".."g".."d".."o".."l".."l")
    task.wait(0.1)
    adminRemote:FireServer(adminUUID, target, "b".."a".."l".."l".."o".."o".."n")
    task.wait(0.1)
    adminRemote:FireServer(adminUUID, target, "j".."a".."i".."l")
end

local function executeBaseDefenderFar(target)
    adminRemote:FireServer(adminUUID, target, "j".."a".."i".."l")
end

local function executeAutoDefense(target)
    adminRemote:FireServer(adminUUID, target, "b".."a".."l".."l".."o".."o".."n")
end

local function getDistanceToBase(player)
    if not player.Character then return math.huge end
    local hrp = getPlayerRootPart(player)
    if not hrp then return math.huge end
    local minDist = math.huge
    for _, podiumPos in ipairs(myPlotAnimalPodiums) do
        local d = (hrp.Position - podiumPos).Magnitude
        if d < minDist then minDist = d end
    end
    return minDist
end

task.spawn(function()
    task.wait(2)
    myPlot = findMyPlot()
    if myPlot then
        myPlotAnimalPodiums = getMyPlotAnimalPodiums(myPlot)
    end
end)

coroutine.wrap(function()
    while true do
        if baseDefenderEnabled and myPlot then
            local playersInPlot = getPlayersInMyPlot()
            if #playersInPlot >= 2 then
                local distances = {}
                for _, plr in ipairs(playersInPlot) do
                    distances[plr] = getDistanceToBase(plr)
                end
                table.sort(playersInPlot, function(a, b)
                    return distances[a] < distances[b]
                end)
                local now = tick()
                local closest = playersInPlot[1]
                local furthest = playersInPlot[#playersInPlot]
                if closest and (not baseDefenderLastUse[closest.UserId] or (now - baseDefenderLastUse[closest.UserId]) > baseDefenderCooldown) then
                    coroutine.wrap(executeBaseDefenderNear)(closest)
                    baseDefenderLastUse[closest.UserId] = now
                end
                if furthest and furthest ~= closest and (not baseDefenderLastUse[furthest.UserId] or (now - baseDefenderLastUse[furthest.UserId]) > baseDefenderCooldown) then
                    coroutine.wrap(executeBaseDefenderFar)(furthest)
                    baseDefenderLastUse[furthest.UserId] = now
                end
            elseif #playersInPlot == 1 then
                local now = tick()
                local player = playersInPlot[1]
                if not baseDefenderLastUse[player.UserId] or (now - baseDefenderLastUse[player.UserId]) > baseDefenderCooldown then
                    coroutine.wrap(executeBaseDefenderNear)(player)
                    baseDefenderLastUse[player.UserId] = now
                end
            end
        end
        task.wait()
    end
end)()

